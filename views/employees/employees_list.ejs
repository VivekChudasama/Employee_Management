<%- include('../includes/head.ejs') %>
    </head>

    <body>
        <%- include('../includes/navigation.ejs') %>

            <main>
                <h1>Employees</h1>
                <a href="/employees/add-employee" class="btn">Add Employee</a>

                <% if (employees.length> 0) { %>
                    <table>
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% employees.forEach(emp=> { %>
                                <tr>
                                    <td>
                                        <%= emp.name %>
                                    </td>
                                    <td>
                                        <%= emp.email %>
                                    </td>
                                    <td>
                                        <%= emp.status %>
                                    </td>
                                    <td>
                                        <a href="/employees/edit-employee/<%= emp.id %>" class="btn">Edit</a>
                                        <form action="/employees/delete-employee" method="POST" style="display:inline;">
                                            <input type="hidden" value="<%= emp.id %>" name="employeeId">
                                            <button class="btn danger" type="submit">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                    <% } else { %>
                        <h1>No Employees Found!</h1>
                        <% } %>
            </main>
            <%- include('../includes/end.ejs') %>